# Copy to `.env` / `.env.local` for local dev. Set in Vercel/hosting for production.

# Canonical site origin (no trailing slash). Used for JSON-LD and absolute canonical URLs.
# VITE_PUBLIC_SITE_URL=https://pesowise.unimisk.com

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Omit to disable analytics.
# VITE_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification — content value only.
# Prefer DNS TXT verification when possible; this is optional.
# VITE_GSC_VERIFICATION=

# Social profile URLs (footer). Leave blank to hide Instagram/YouTube until live.
# VITE_SOCIAL_LINKEDIN_URL=https://www.linkedin.com/company/pesowise
# VITE_SOCIAL_TWITTER_URL=https://twitter.com/pesowise
# VITE_SOCIAL_INSTAGRAM_URL=
# VITE_SOCIAL_YOUTUBE_URL=
